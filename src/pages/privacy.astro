---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habiterr | Privacy</title>
    <meta name="theme-color" content="#06080e" />
  </head>
  <body>
    <main class="legal-page">
      <section class="legal-card">
        <a class="legal-back" href="/">← Back to Habiterr</a>
        <p class="eyebrow">Privacy</p>
        <h1>Privacy policy placeholder</h1>
        <p>
          Add your final privacy policy here before release. The current page is intentionally short so the footer has a working destination during design and staging.
        </p>
        <div class="legal-block">
          <h2>Include before launch</h2>
          <ul class="legal-list">
            <li>What habit data is stored on device or in the cloud.</li>
            <li>Whether analytics, crash reporting, or notifications are used.</li>
            <li>How users can request deletion or contact support.</li>
          </ul>
        </div>
      </section>
    </main>
  </body>
</html>
