---
import "../styles/global.css";

const appStoreUrl = "https://apps.apple.com/";

const overviewStats = [
  { value: "2 taps", label: "to log a habit" },
  { value: "Quiet UI", label: "built for daily use" },
  { value: "3 views", label: "to spot your pattern" }
];

const upcomingItems = [
  {
    title: "Shared habits",
    text: "Invite a partner, coach, or team and keep the same clean view."
  },
  {
    title: "Smart reminders",
    text: "Nudges adapt to your streaks instead of spamming at fixed times."
  },
  {
    title: "Monthly reviews",
    text: "Auto-generated summaries to surface the habits that actually stick."
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habiterr | Habit Tracking for iPhone</title>
    <meta name="theme-color" content="#06080e" />
    <meta
      name="description"
      content="Habiterr is a stylish iPhone habit tracker with clear streaks, calm visuals, and fast daily check-ins."
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="hero" id="top">
        <div class="hero__orb hero__orb--left"></div>
        <div class="hero__orb hero__orb--right"></div>
        <nav class="topbar">
          <a class="brand" href="#top" aria-label="Habiterr home">
            <span class="brand__mark">
              <span></span>
            </span>
            <span class="brand__text">Habiterr</span>
          </a>
          <div class="topbar__links">
            <a href="#features">Features</a>
            <a href="#coming-soon">Coming soon</a>
            <a href="#contact">Contact</a>
          </div>
        </nav>

        <div class="hero__grid">
          <div class="hero__copy">
            <p class="eyebrow">A habit tracker with enough glow to feel alive, and enough restraint to stay useful.</p>
            <h1>Track consistency with a calmer, sharper iPhone experience.</h1>
            <p class="hero__lede">
              Habiterr turns streaks, misses, and momentum into a quick visual scan. Open it, feel where the week is going, and move on.
            </p>

            <div class="hero__actions">
              <a class="app-store-button" href={appStoreUrl} target="_blank" rel="noreferrer">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M16.37 12.18c.02 2.18 1.91 2.91 1.93 2.92-.02.05-.3 1.05-.98 2.08-.58.89-1.2 1.78-2.15 1.8-.93.02-1.23-.55-2.3-.55-1.07 0-1.4.53-2.28.57-.92.03-1.62-.93-2.21-1.82-1.21-1.75-2.14-4.95-.9-7.1.62-1.07 1.72-1.75 2.92-1.77.91-.02 1.76.61 2.3.61.54 0 1.56-.75 2.63-.64.45.02 1.71.18 2.52 1.37-.07.04-1.49.87-1.48 2.53zM14.9 5.3c.49-.59.82-1.42.73-2.24-.71.03-1.57.48-2.08 1.07-.46.54-.86 1.39-.75 2.2.79.06 1.61-.4 2.1-1.03z"
                  />
                </svg>
                <span>
                  <small>Download on the</small>
                  <strong>App Store</strong>
                </span>
              </a>
              <a class="ghost-button" href="#features">See the flow</a>
            </div>

            <div class="hero__stats">
              {
                overviewStats.map((stat) => (
                  <div class="stat-pill">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="hero__visual">
            <div class="hero__floating hero__floating--top">
              <span class="hero__floating-label">Today</span>
              <strong>4 habits on track</strong>
            </div>
            <div class="hero__floating hero__floating--bottom">
              <span class="hero__floating-label">Momentum</span>
              <strong>17-day longest streak</strong>
            </div>

            <div class="device-frame">
              <img src="/screenshots/1.PNG" alt="Habiterr app screenshot" class="hero-screenshot" />
            </div>
          </div>
        </div>
      </header>

      <main>
        <section class="section section--intro">
          <div class="section-heading">
            <p class="eyebrow">Designed for repeat use</p>
            <h2>The landing stays short because the product does too.</h2>
            <p>
              Habiterr focuses on quick recognition: what was done, what is slipping, and where your next streak comes from.
            </p>
          </div>
        </section>

        <section class="section features" id="features">
          <article class="feature feature--reverse">
            <div class="feature__copy">
              <p class="feature__eyebrow">Clean interface</p>
              <h3>Built for daily use, not daily frustration.</h3>
              <p>
                A compact layout that puts stats and check-ins front and center. See streaks, completion rates, and heatmaps at a glance — then move on with your day.
              </p>
              <ul class="feature__list">
                <li>Per-habit stats with streaks and completion rates</li>
                <li>Compact card layout fits more habits on screen</li>
                <li>One-tap checking — no extra screens or menus</li>
                <li>Dark theme that feels calm, not clinical</li>
              </ul>
            </div>

            <div class="feature__visual feature__visual--dual">
              <img src="/screenshots/1.PNG" alt="Habiterr main habit list" class="feature-screenshot" />
              <img src="/screenshots/2.PNG" alt="Habiterr habit detail view" class="feature-screenshot" />
            </div>
          </article>

          <article class="feature">
            <div class="feature__copy">
              <p class="feature__eyebrow">Smart integrations</p>
              <h3>Let your data do the checking for you.</h3>
              <p>
                Connect habits to HealthKit and other sources so progress logs itself. Set custom checking rules and let integrations handle the rest — with more sources on the way.
              </p>
              <ul class="feature__list">
                <li>HealthKit integration for steps, workouts, and more</li>
                <li>Flexible checking rules per habit</li>
                <li>Auto-check habits based on real activity data</li>
                <li>More integrations coming soon</li>
              </ul>
            </div>

            <div class="feature__visual feature__visual--dual">
              <img src="/screenshots/3.PNG" alt="Habiterr integrations setup" class="feature-screenshot" />
              <img src="/screenshots/6.PNG" alt="Habiterr HealthKit integration" class="feature-screenshot" />
            </div>
          </article>

          <article class="feature feature--reverse">
            <div class="feature__copy">
              <p class="feature__eyebrow">Balance chart</p>
              <h3>See the bigger picture of your progress.</h3>
              <p>
                The balance chart gives you a visual snapshot of how your habits trend over time. Spot patterns, catch slumps early, and stay on course without overthinking.
              </p>
              <ul class="feature__list">
                <li>Visual trend line across all your habits</li>
                <li>Quickly spot dips and rebounds</li>
                <li>Progress tracking that motivates, not overwhelms</li>
              </ul>
            </div>

            <div class="feature__visual">
              <img src="/screenshots/4.PNG" alt="Habiterr balance chart" class="feature-screenshot" />
            </div>
          </article>

          <article class="feature">
            <div class="feature__copy">
              <p class="feature__eyebrow">iOS widgets</p>
              <h3>Your habits, always one glance away.</h3>
              <p>
                Add widgets to your home screen to keep habits visible without opening the app. Quick-check directly from the widget and stay on track throughout the day.
              </p>
              <ul class="feature__list">
                <li>Home screen widgets for habit overview</li>
                <li>Quick check-in right from the widget</li>
                <li>Keep habits visible without opening the app</li>
              </ul>
            </div>

            <div class="feature__visual">
              <img src="/screenshots/5.PNG" alt="Habiterr iOS widgets" class="feature-screenshot" />
            </div>
          </article>

          <article class="feature feature--reverse">
            <div class="feature__copy">
              <p class="feature__eyebrow">Timers & counters</p>
              <h3>Track more than just done or not done.</h3>
              <p>
                Some habits need precision. Use built-in timers for exercise sessions, reading time, or meditation — and counters for pages read, glasses of water, or reps completed.
              </p>
              <ul class="feature__list">
                <li>Built-in timer for time-based habits</li>
                <li>Counter mode for quantity-based tracking</li>
                <li>Track pages, minutes, reps, and more</li>
              </ul>
            </div>

            <div class="feature__visual feature__visual--dual">
              <img src="/screenshots/7.PNG" alt="Habiterr timer habit" class="feature-screenshot" />
              <img src="/screenshots/8.PNG" alt="Habiterr counter habit" class="feature-screenshot" />
            </div>
          </article>
        </section>

        <section class="section coming-soon" id="coming-soon">
          <div class="section-heading">
            <p class="eyebrow">Coming soon</p>
            <h2>Next up: more support, same restraint.</h2>
            <p>
              The roadmap expands the app without breaking the core promise: daily use should stay quick, visual, and calm.
            </p>
          </div>

          <div class="upcoming-grid">
            {
              upcomingItems.map((item) => (
                <article class="upcoming-card">
                  <div class="upcoming-card__glow"></div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer" id="contact">
        <div class="site-footer__brand">
          <a class="brand" href="#top" aria-label="Habiterr home">
            <span class="brand__mark">
              <span></span>
            </span>
            <span class="brand__text">Habiterr</span>
          </a>
          <p>
            Habit tracking for iPhone with a visual rhythm-first interface. Swap in your real App Store URL and legal pages before launch.
          </p>
        </div>

        <div class="site-footer__links" id="legal">
          <a href="mailto:hello@habiterr.app">hello@habiterr.app</a>
          <a href="mailto:press@habiterr.app">Press kit</a>
          <a href="/license">License</a>
          <a href="/privacy">Privacy</a>
          <a href="#contact">Contact</a>
        </div>
      </footer>
    </div>
  </body>
</html>
