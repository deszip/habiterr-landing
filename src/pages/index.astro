---
import "../styles/global.css";

const appStoreUrl = "https://apps.apple.com/";

const overviewStats = [
  { value: "2 taps", label: "to log a habit" },
  { value: "Quiet UI", label: "built for daily use" },
  { value: "3 views", label: "to spot your pattern" }
];

const heroCards = [
  {
    title: "Some long habit name that does...",
    tone: "blue",
    alerts: ["2", "1", "12"],
    action: "done",
    activeCells: [5, 6, 12, 13, 19, 21, 26, 27, 28, 33, 34, 35, 40, 41]
  },
  {
    title: "2",
    tone: "green",
    alerts: ["0", "2", "2"],
    action: "add",
    activeCells: [3, 10, 17, 18, 25, 32, 39]
  },
  {
    title: "3",
    tone: "teal",
    alerts: ["0", "4", "4"],
    action: "timer",
    activeCells: [6, 13, 20, 27, 34, 35, 42]
  },
  {
    title: "Foo",
    tone: "cyan",
    alerts: ["0", "1", "2"],
    action: "add",
    activeCells: [6, 14, 22, 29, 36]
  }
];

const upcomingItems = [
  {
    title: "Shared habits",
    text: "Invite a partner, coach, or team and keep the same clean view."
  },
  {
    title: "Smart reminders",
    text: "Nudges adapt to your streaks instead of spamming at fixed times."
  },
  {
    title: "Monthly reviews",
    text: "Auto-generated summaries to surface the habits that actually stick."
  }
];

const iconPaths = {
  blue: "M12 3.5l2.45 4.96 5.47.79-3.96 3.86.93 5.45L12 16.98 7.11 18.56l.93-5.45-3.96-3.86 5.47-.79L12 3.5z",
  green: "M12 4l2.2 4.46L19 9.15l-3.5 3.4.83 4.8L12 15.74 7.67 17.35l.83-4.8L5 9.15l4.8-.69L12 4z",
  teal: "M12 3.5l1.74 5.36h5.64l-4.56 3.31 1.74 5.36L12 14.22 7.44 17.53l1.74-5.36-4.56-3.31h5.64L12 3.5z",
  cyan: "M10.08 5.18A1 1 0 0111 4.5h2a1 1 0 01.92.68l.78 2.32 2.44.84a1 1 0 01.6 1.47l-1.46 2.18 1.46 2.18a1 1 0 01-.6 1.47l-2.44.84-.78 2.32A1 1 0 0113 19.5h-2a1 1 0 01-.92-.68l-.78-2.32-2.44-.84a1 1 0 01-.6-1.47L6.72 12 5.26 9.82a1 1 0 01.6-1.47l2.44-.84.78-2.32z"
};

const actionLabels = {
  done: "check",
  add: "add",
  timer: "timer"
};

const months = ["Dec", "Jan", "Feb", "Mar"];

const renderCells = (activeCells) =>
  Array.from({ length: 49 }, (_, index) => ({
    active: activeCells.includes(index)
  }));

const focusHeatmap = renderCells([4, 5, 11, 12, 18, 24, 25, 26, 31, 38, 45]);
const rhythmHeatmap = renderCells([0, 2, 9, 10, 17, 18, 24, 31, 32, 39, 46, 47]);
const clarityHeatmap = renderCells([6, 12, 13, 19, 25, 26, 33, 34, 40, 41, 48]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habiterr | Habit Tracking for iPhone</title>
    <meta name="theme-color" content="#06080e" />
    <meta
      name="description"
      content="Habiterr is a stylish iPhone habit tracker with clear streaks, calm visuals, and fast daily check-ins."
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="hero" id="top">
        <div class="hero__orb hero__orb--left"></div>
        <div class="hero__orb hero__orb--right"></div>
        <nav class="topbar">
          <a class="brand" href="#top" aria-label="Habiterr home">
            <span class="brand__mark">
              <span></span>
            </span>
            <span class="brand__text">Habiterr</span>
          </a>
          <div class="topbar__links">
            <a href="#features">Features</a>
            <a href="#coming-soon">Coming soon</a>
            <a href="#contact">Contact</a>
          </div>
        </nav>

        <div class="hero__grid">
          <div class="hero__copy">
            <p class="eyebrow">A habit tracker with enough glow to feel alive, and enough restraint to stay useful.</p>
            <h1>Track consistency with a calmer, sharper iPhone experience.</h1>
            <p class="hero__lede">
              Habiterr turns streaks, misses, and momentum into a quick visual scan. Open it, feel where the week is going, and move on.
            </p>

            <div class="hero__actions">
              <a class="app-store-button" href={appStoreUrl} target="_blank" rel="noreferrer">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M16.37 12.18c.02 2.18 1.91 2.91 1.93 2.92-.02.05-.3 1.05-.98 2.08-.58.89-1.2 1.78-2.15 1.8-.93.02-1.23-.55-2.3-.55-1.07 0-1.4.53-2.28.57-.92.03-1.62-.93-2.21-1.82-1.21-1.75-2.14-4.95-.9-7.1.62-1.07 1.72-1.75 2.92-1.77.91-.02 1.76.61 2.3.61.54 0 1.56-.75 2.63-.64.45.02 1.71.18 2.52 1.37-.07.04-1.49.87-1.48 2.53zM14.9 5.3c.49-.59.82-1.42.73-2.24-.71.03-1.57.48-2.08 1.07-.46.54-.86 1.39-.75 2.2.79.06 1.61-.4 2.1-1.03z"
                  />
                </svg>
                <span>
                  <small>Download on the</small>
                  <strong>App Store</strong>
                </span>
              </a>
              <a class="ghost-button" href="#features">See the flow</a>
            </div>

            <div class="hero__stats">
              {
                overviewStats.map((stat) => (
                  <div class="stat-pill">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="hero__visual">
            <div class="hero__floating hero__floating--top">
              <span class="hero__floating-label">Today</span>
              <strong>4 habits on track</strong>
            </div>
            <div class="hero__floating hero__floating--bottom">
              <span class="hero__floating-label">Momentum</span>
              <strong>17-day longest streak</strong>
            </div>

            <div class="device-frame">
              <div class="device-frame__notch"></div>
              <div class="device-screen">
                <div class="status-bar">
                  <span>11:42</span>
                  <div class="status-bar__icons">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                </div>

                <div class="screen-icons">
                  <div class="screen-app-icon">
                    <span></span>
                  </div>
                  <div class="screen-app-icon screen-app-icon--small">
                    <span></span>
                  </div>
                </div>

                <div class="habit-list">
                  {
                    heroCards.map((card, index) => (
                      <article class:list={["habit-card", `habit-card--${card.tone}`, index === 0 && "is-selected"]}>
                        <div class="habit-card__header">
                          <div class="habit-card__title-wrap">
                            <div class="habit-card__icon">
                              <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d={iconPaths[card.tone]}></path>
                              </svg>
                            </div>
                            <div>
                              <h2>{card.title}</h2>
                              <div class="habit-card__chips">
                                <span>{card.alerts[0]}</span>
                                <span>{card.alerts[1]}</span>
                                <span>{card.alerts[2]}</span>
                              </div>
                            </div>
                          </div>

                          <button class="habit-card__action" type="button" aria-label={actionLabels[card.action]}>
                            {
                              card.action === "done" ? (
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                  <path d="M9.6 16.2L5.8 12.4l-1.4 1.4 5.2 5.2L20 8.6l-1.4-1.4z"></path>
                                </svg>
                              ) : card.action === "add" ? (
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                  <path d="M11 5h2v14h-2zM5 11h14v2H5z"></path>
                                </svg>
                              ) : (
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                  <path d="M12 7h1.4v5.1l4.1 2.4-.7 1.2L12 13V7zm0-5a10 10 0 100 20 10 10 0 000-20zm0 1.6a8.4 8.4 0 110 16.8 8.4 8.4 0 010-16.8z"></path>
                                </svg>
                              )
                            }
                          </button>
                        </div>

                        <div class="habit-card__months">
                          {months.map((month) => <span>{month}</span>)}
                        </div>
                        <div class="heatmap">
                          {
                            renderCells(card.activeCells).map((cell) => (
                              <span class:list={["heatmap__cell", cell.active && "is-active"]}></span>
                            ))
                          }
                        </div>
                      </article>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main>
        <section class="section section--intro">
          <div class="section-heading">
            <p class="eyebrow">Designed for repeat use</p>
            <h2>The landing stays short because the product does too.</h2>
            <p>
              Habiterr focuses on quick recognition: what was done, what is slipping, and where your next streak comes from.
            </p>
          </div>
        </section>

        <section class="section features" id="features">
          <article class="feature feature--reverse">
            <div class="feature__copy">
              <p class="feature__eyebrow">Visual focus</p>
              <h3>See your streaks in one glance.</h3>
              <p>
                Dense heatmaps make it obvious where momentum is building. Bright wins stay visible without turning the whole interface into noise.
              </p>
              <ul class="feature__list">
                <li>Fast check-ins from the main list</li>
                <li>Long habit names still stay readable</li>
                <li>Color-coded status without clutter</li>
              </ul>
            </div>

            <div class="feature__visual">
              <div class="screen-card">
                <div class="screen-card__header">
                  <span>Focus</span>
                  <strong>Weekly streaks</strong>
                </div>
                <div class="screen-card__metric-row">
                  <div class="screen-card__metric is-blue">
                    <strong>17</strong>
                    <span>best streak</span>
                  </div>
                  <div class="screen-card__metric is-emerald">
                    <strong>86%</strong>
                    <span>completion</span>
                  </div>
                </div>
                <div class="mini-months">
                  {months.map((month) => <span>{month}</span>)}
                </div>
                <div class="heatmap heatmap--focus">
                  {
                    focusHeatmap.map((cell) => (
                      <span class:list={["heatmap__cell", cell.active && "is-active"]}></span>
                    ))
                  }
                </div>
              </div>
            </div>
          </article>

          <article class="feature">
            <div class="feature__copy">
              <p class="feature__eyebrow">Gentle structure</p>
              <h3>Make daily progress feel tactile, not heavy.</h3>
              <p>
                Each habit card keeps the controls close and the state obvious. The interface keeps you moving instead of making you manage a dashboard.
              </p>
              <ul class="feature__list">
                <li>Tap targets designed for one-handed use</li>
                <li>Primary actions always visible</li>
                <li>Consistent glow and contrast on dark mode</li>
              </ul>
            </div>

            <div class="feature__visual">
              <div class="screen-card screen-card--rings">
                <div class="screen-card__header">
                  <span>Rhythm</span>
                  <strong>Today at a glance</strong>
                </div>
                <div class="ring-cluster">
                  <div class="ring ring--lg">
                    <div>
                      <strong>4/5</strong>
                      <span>done</span>
                    </div>
                  </div>
                  <div class="ring-stack">
                    <div class="ring ring--sm ring--blue">
                      <div>
                        <strong>82%</strong>
                        <span>week</span>
                      </div>
                    </div>
                    <div class="ring ring--sm ring--teal">
                      <div>
                        <strong>12</strong>
                        <span>days</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="heatmap heatmap--rhythm">
                  {
                    rhythmHeatmap.map((cell) => (
                      <span class:list={["heatmap__cell", cell.active && "is-active"]}></span>
                    ))
                  }
                </div>
              </div>
            </div>
          </article>

          <article class="feature feature--reverse">
            <div class="feature__copy">
              <p class="feature__eyebrow">Pattern clarity</p>
              <h3>Review your habits without drowning in charts.</h3>
              <p>
                Habiterr keeps the insights layer readable: enough structure to spot misses and rebounds, without turning the app into analytics software.
              </p>
              <ul class="feature__list">
                <li>Readable weekly snapshots</li>
                <li>Simple cards for habits that need attention</li>
                <li>Space for future coaching and reminders</li>
              </ul>
            </div>

            <div class="feature__visual">
              <div class="screen-card screen-card--insights">
                <div class="screen-card__header">
                  <span>Clarity</span>
                  <strong>Review patterns</strong>
                </div>
                <div class="insight-stack">
                  <div class="insight-tile">
                    <small>Most consistent</small>
                    <strong>Morning walk</strong>
                    <span>10 completed in a row</span>
                  </div>
                  <div class="insight-tile insight-tile--accent">
                    <small>Needs attention</small>
                    <strong>Read 20 min</strong>
                    <span>2 misses this week</span>
                  </div>
                </div>
                <div class="heatmap heatmap--clarity">
                  {
                    clarityHeatmap.map((cell) => (
                      <span class:list={["heatmap__cell", cell.active && "is-active"]}></span>
                    ))
                  }
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="section coming-soon" id="coming-soon">
          <div class="section-heading">
            <p class="eyebrow">Coming soon</p>
            <h2>Next up: more support, same restraint.</h2>
            <p>
              The roadmap expands the app without breaking the core promise: daily use should stay quick, visual, and calm.
            </p>
          </div>

          <div class="upcoming-grid">
            {
              upcomingItems.map((item) => (
                <article class="upcoming-card">
                  <div class="upcoming-card__glow"></div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer" id="contact">
        <div class="site-footer__brand">
          <a class="brand" href="#top" aria-label="Habiterr home">
            <span class="brand__mark">
              <span></span>
            </span>
            <span class="brand__text">Habiterr</span>
          </a>
          <p>
            Habit tracking for iPhone with a visual rhythm-first interface. Swap in your real App Store URL and legal pages before launch.
          </p>
        </div>

        <div class="site-footer__links" id="legal">
          <a href="mailto:hello@habiterr.app">hello@habiterr.app</a>
          <a href="mailto:press@habiterr.app">Press kit</a>
          <a href="/license">License</a>
          <a href="/privacy">Privacy</a>
          <a href="#contact">Contact</a>
        </div>
      </footer>
    </div>
  </body>
</html>
