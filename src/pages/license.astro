---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habiterr | License</title>
    <meta name="theme-color" content="#06080e" />
  </head>
  <body>
    <main class="legal-page">
      <section class="legal-card">
        <a class="legal-back" href="/">← Back to Habiterr</a>
        <p class="eyebrow">License</p>
        <h1>Launch assets and rights</h1>
        <p>
          This landing page is a launch-ready placeholder. Replace this copy with your production license text before publishing the app or distributing branded assets.
        </p>
        <div class="legal-block">
          <h2>Suggested structure</h2>
          <ul class="legal-list">
            <li>Name the legal owner of the Habiterr brand and app content.</li>
            <li>Clarify whether screenshots, icons, and copy may be reused.</li>
            <li>State any open-source acknowledgements used in the shipped app.</li>
          </ul>
        </div>
      </section>
    </main>
  </body>
</html>
